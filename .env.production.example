# =============================================================
# .env.production — supply-chain-ams-stack
# =============================================================
# Copiar a .env y completar valores ANTES de levantar el stack:
#   cp .env.production.example .env
#   nano .env
#
# NUNCA commitear este archivo con valores reales.
# =============================================================

# ----- Dominios -----
# El VPS debe tener registros DNS A apuntando estos dominios a su IP pública.
AMS_DOMAIN=ams.miespejo.cl
AMS_API_DOMAIN=api.ams.miespejo.cl

# Para deshabilitar HTTPS (sólo desarrollo local), usar dominios .localhost
# o agregar `auto_https off` al Caddyfile.

# ----- LLM provider -----
# Obtener en https://aistudio.google.com/app/apikey (free tier muy generoso)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Opcional, si querés usar Claude en lugar de Gemini para algo específico:
# ANTHROPIC_API_KEY=

# ----- Base de datos -----
# IMPORTANTE: generá una password fuerte. Sugerencia:
#   openssl rand -base64 32
POSTGRES_USER=ams_user
POSTGRES_PASSWORD=cambiame-pega-output-de-openssl-rand
POSTGRES_DB=ams_agent
# DATABASE_URL se autocalcula en docker-compose.prod.yml con los valores de arriba.

# ----- Auth -----
# Secret aleatorio de al menos 32 chars. Generar con: openssl rand -hex 32
COOKIE_SECRET=
JWT_SECRET=
# Bcrypt: 12 rounds = ~250ms en CPU típica. 14 = 1s (más seguro pero login lento).
AUTH_BCRYPT_ROUNDS=12

# Bootstrap admin (solo se aplica si la DB está vacía)
AMS_BOOTSTRAP_ADMIN_EMAIL=admin@tudominio.cl
AMS_BOOTSTRAP_ADMIN_PASSWORD=cambiame-password-fuerte-de-12chars-min

# ----- CORS -----
# Si el frontend está en ams.miespejo.cl y la API en api.ams.miespejo.cl:
CORS_ORIGINS=https://ams.miespejo.cl

# ----- Frontend → API base URL -----
# El navegador llamará a este URL para /api/*. Debe coincidir con AMS_API_DOMAIN.
NEXT_PUBLIC_AGENT_API_URL=https://api.ams.miespejo.cl

# ----- Whisper (sólo si activás --profile voice) -----
# Si no activás voice, el backend cae a mock en /api/meetings y /api/testing/...
WHISPER_URL=http://whisper:9000

# ----- RAG -----
RAG_ENABLED=true
RAG_TOP_K=6
RAG_MIN_SCORE=0.55
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIM=768
RAG_CHUNK_CHARS=3500
RAG_CHUNK_OVERLAP=400

# =============================================================
# INTEGRACIONES (todas opcionales)
# Si no se setean, los adapters caen a modo DEMO y nunca llaman afuera.
# =============================================================

# Jira Atlassian Cloud
# JIRA_ENABLED=true
# JIRA_BASE_URL=https://tuempresa.atlassian.net
# JIRA_USER_EMAIL=tu@empresa.com
# JIRA_API_TOKEN=ATATT3xFfGF0...
# JIRA_PROJECT_KEY=AMS

# ServiceNow
# SERVICENOW_ENABLED=true
# SERVICENOW_INSTANCE_URL=https://devXXXXX.service-now.com
# SERVICENOW_USERNAME=integration_user
# SERVICENOW_TOKEN=...
# SERVICENOW_TABLE=incident

# SAP Cloud ALM (OAuth2 client_credentials)
# CLOUD_ALM_ENABLED=true
# CLOUD_ALM_TENANT_URL=https://eu10.alm.cloud.sap
# CLOUD_ALM_TOKEN_URL=https://your-subaccount.authentication.eu10.hana.ondemand.com/oauth/token
# CLOUD_ALM_CLIENT_ID=
# CLOUD_ALM_CLIENT_SECRET=
# CLOUD_ALM_TEST_ENDPOINT=/v1/test-cases

# Twilio Voice
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_PHONE_NUMBER=+56xxxxxxxxx
VOICE_DEFAULT_LANGUAGE=es-CL
VOICE_DEFAULT_VOICE=alice
GEMINI_VOICE_MODEL=gemini-2.5-flash-lite

# SAP Read-Only (OData)
# SAP_BASE_URL=https://my-s4.cliente.com
# SAP_USER=AMS_AGENT_RO
# SAP_PASSWORD=
# SAP_CLIENT=100
# SAP_READONLY_ENABLED=true

# SMTP para envíos de email
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu@empresa.com
# SMTP_PASSWORD=app-password-de-16-chars
# SMTP_FROM="AMS Platform <ams-bot@empresa.com>"

# =============================================================
# Observabilidad (todas opcionales)
# =============================================================

# Sentry (errores frontend + backend). Dejar vacío para deshabilitar.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05

# Grafana (sólo si activás --profile observability)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=cambiame-grafana

# =============================================================
# Tuning runtime
# =============================================================

LOG_LEVEL=info
# Whisper model size: tiny / base / small / medium / large
# base = 150MB, small = 460MB, medium = 1.5GB. En VPS chico usar tiny o base.
ASR_MODEL=base

# Caddy: basic auth opcional para gate de toda la plataforma.
# Generar el hash con: docker run --rm caddy:2-alpine caddy hash-password --plaintext "tu-pass"
# Después definir aquí: AMS_BASIC_AUTH="usuario hash-bcrypt"
# Y descomentar la sección basic_auth en Caddyfile.prod.
AMS_BASIC_AUTH=

# =============================================================
# Puertos internos
# =============================================================
BACKEND_PORT=8000
NODE_ENV=production
