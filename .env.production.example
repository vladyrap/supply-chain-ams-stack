# =============================================================
# .env.production — supply-chain-ams-stack (v1.1.3 audit-ready)
# =============================================================
# Copiar a .env y completar valores ANTES de levantar el stack:
#   cp .env.production.example .env
#   nano .env
#
# NUNCA commitear este archivo con valores reales.
#
# Las vars marcadas ?required hacen FALLAR docker compose up si están vacías.
# Las marcadas FAIL-FAST hacen FALLAR el boot del backend si están vacías o
# no cumplen los requisitos (NODE_ENV=production).
# =============================================================

# ----- Dominios -----
# El VPS debe tener registros DNS A apuntando estos dominios a su IP pública.
AMS_DOMAIN=ams.miespejo.cl
AMS_API_DOMAIN=api.ams.miespejo.cl
# Dominio base para validar subdomains de tenants (multi-tenancy mode=subdomain).
# Ejemplo: si PUBLIC_BASE_DOMAIN=miespejo.cl, "acme.miespejo.cl" se resuelve
# a tenant "acme". Sin esto, subdomain mode no funciona.
PUBLIC_BASE_DOMAIN=miespejo.cl

# ----- LLM provider -----
# Obtener en https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Caps defensivos contra cobros inesperados (ver utils/gemini-rate-limiter.ts)
GEMINI_CAP_PER_MINUTE=20
GEMINI_CAP_PER_HOUR=80
GEMINI_CAP_PER_DAY=200

# Anthropic (v1.3 onda 4.1) — requerida SOLO si se crean agentes custom con
# modelos Claude (Opus/Sonnet/Haiku) en el Agent Builder. Sin esta key, esos
# agentes devuelven error claro y los Gemini siguen funcionando normal.
# Obtener en https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ----- Base de datos -----
# IMPORTANTE: ?required en compose. Generar con: openssl rand -base64 32
POSTGRES_USER=ams_user
POSTGRES_PASSWORD=
POSTGRES_DB=ams_agent
# DATABASE_URL se autocalcula en docker-compose.prod.yml.

# Pool tuning (defaults razonables — override si carga lo requiere)
PG_POOL_MAX=25
PG_POOL_MIN=2
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECTION_TIMEOUT_MS=5000
PG_STATEMENT_TIMEOUT_MS=15000
PG_QUERY_TIMEOUT_MS=20000

# ----- Auth + cookies (FAIL-FAST en prod si vacías o < 32 chars) -----
# Generar cada una con: openssl rand -hex 32
COOKIE_SECRET=
JWT_SECRET=
JWT_TTL_HOURS=8
AUTH_BCRYPT_ROUNDS=12

# Signup público — SIEMPRE false en prod (evita race condition admin bootstrap)
# Para crear primer admin: usar AMS_BOOTSTRAP_ADMIN_* abajo o seed CLI.
ENABLE_PUBLIC_SIGNUP=false

# Bootstrap admin (solo se aplica si la DB está vacía al primer boot)
AMS_BOOTSTRAP_ADMIN_EMAIL=admin@tudominio.cl
AMS_BOOTSTRAP_ADMIN_PASSWORD=cambiame-password-fuerte-de-12chars-min

# ----- Multi-tenancy -----
# Modos: single | header | subdomain | hybrid (recomendado prod multi-cliente)
#   single    — un solo tenant, ignora header/subdomain
#   header    — X-Tenant-Id header (solo super_admin) + JWT
#   subdomain — subdomain del host (requiere PUBLIC_BASE_DOMAIN) + JWT
#   hybrid    — todos los métodos, JWT siempre primero
MULTI_TENANCY_MODE=hybrid
DEFAULT_TENANT_ID=default

# ----- Rate limit -----
# Global por IP (req/min). 200 es razonable para tráfico normal.
RATE_LIMIT_MAX_PER_MIN=200
# Allowlist por IP (NO incluir 127.0.0.1 en prod — spoof XFF posible).
# Solo poblar si necesitás bypass legítimo (ej: monitoreo interno).
RATE_LIMIT_ALLOWLIST=
# Login/signup/oauth-callback (estricto — anti brute force)
AUTH_RATE_LIMIT_MAX=8
AUTH_RATE_LIMIT_WINDOW=1 minute

# ----- CSRF -----
# Si false, NO se valida Origin/Referer en mutations. NUNCA en prod.
ENFORCE_ORIGIN_CSRF=true
# Tokens HMAC para clientes legítimos sin browser (server-to-server, lambda, etc).
# Lista separada por coma. Vacío = solo paths whitelisted (Twilio, SAP) pueden saltar CSRF.
CSRF_BYPASS_TOKENS=

# ----- CORS -----
# Frontend en ams.miespejo.cl + API en api.ams.miespejo.cl
CORS_ORIGINS=https://ams.miespejo.cl

# ----- SSO Google OAuth (opcional — no-op si vacío) -----
# Setup: https://console.cloud.google.com/apis/credentials
# Si activás, PUBLIC_BASE_URL DEBE ser https:// en prod (FAIL-FAST).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Dominios permitidos (CSV). Si vacío, acepta cualquier email con verified_email=true.
GOOGLE_OAUTH_ALLOWED_DOMAINS=
PUBLIC_BASE_URL=https://ams.miespejo.cl

# ----- Email transaccional Resend (opcional) -----
# Setup: https://resend.com — free tier 100 emails/día.
# Si vacío, sendWelcome / sendPasswordReset / sendAlertNotification son no-op.
RESEND_API_KEY=
EMAIL_FROM=AMS Platform <noreply@miespejo.cl>

# ----- Frontend → API base URL -----
NEXT_PUBLIC_AGENT_API_URL=https://api.ams.miespejo.cl

# ----- Whisper (sólo si --profile voice) -----
WHISPER_URL=http://whisper:9000
ASR_MODEL=base

# ----- RAG -----
RAG_ENABLED=true
RAG_TOP_K=6
RAG_MIN_SCORE=0.55
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIM=768
RAG_CHUNK_CHARS=3500
RAG_CHUNK_OVERLAP=400

# =============================================================
# INTEGRACIONES (todas opcionales — caen a modo DEMO si no configuradas)
# =============================================================

# Jira Atlassian Cloud
# JIRA_ENABLED=true
# JIRA_BASE_URL=https://tuempresa.atlassian.net
# JIRA_USER_EMAIL=tu@empresa.com
# JIRA_API_TOKEN=ATATT3xFfGF0...
# JIRA_PROJECT_KEY=AMS

# ServiceNow
# SERVICENOW_ENABLED=true
# SERVICENOW_INSTANCE_URL=https://devXXXXX.service-now.com
# SERVICENOW_USERNAME=integration_user
# SERVICENOW_TOKEN=...

# SAP Cloud ALM (OAuth2)
# CLOUD_ALM_ENABLED=true
# CLOUD_ALM_TENANT_URL=https://eu10.alm.cloud.sap
# CLOUD_ALM_TOKEN_URL=https://your-subaccount.authentication.eu10.hana.ondemand.com/oauth/token
# CLOUD_ALM_CLIENT_ID=
# CLOUD_ALM_CLIENT_SECRET=

# Twilio Voice
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+56xxxxxxxxx
VOICE_DEFAULT_LANGUAGE=es-CL
VOICE_DEFAULT_VOICE=alice
GEMINI_VOICE_MODEL=gemini-2.5-flash-lite

# SAP Read-Only (OData)
# SAP_BASE_URL=https://my-s4.cliente.com
# SAP_USER=AMS_AGENT_RO
# SAP_PASSWORD=
# SAP_CLIENT=100
# SAP_READONLY_ENABLED=true

# =============================================================
# Observabilidad
# =============================================================

# Sentry (errores frontend + backend). Vacío = deshabilitado.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
NEXT_PUBLIC_SENTRY_TRACES_RATE=0.1

# Grafana — ?required en compose si activás --profile observability
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# Alertmanager → Slack / PagerDuty / Email
# Vacío = alertas se loguean pero no salen.
SLACK_WEBHOOK_URL=
PAGERDUTY_KEY=
ALERTMANAGER_SMTP_HOST=
ALERTMANAGER_SMTP_FROM=alerts@miespejo.cl
ALERTMANAGER_SMTP_USERNAME=
ALERTMANAGER_SMTP_PASSWORD=
ALERTMANAGER_TO=alerts@miespejo.cl

# =============================================================
# Frontend platform — vars públicas (van al bundle JS)
# =============================================================
NEXT_PUBLIC_SALES_EMAIL=ventas@miespejo.cl
NEXT_PUBLIC_SUPPORT_EMAIL=soporte@miespejo.cl
NEXT_PUBLIC_COMPANY_NAME=AMS Platform SpA

# =============================================================
# Tuning runtime
# =============================================================

LOG_LEVEL=info
NODE_ENV=production
BACKEND_PORT=8000

# Caddy basic auth opcional (gate global)
# Generar: docker run --rm caddy:2-alpine caddy hash-password --plaintext "tu-pass"
AMS_BASIC_AUTH=

# Tipo de cambio USD/CLP para /admin/costs (override si necesario)
USD_TO_CLP_RATE=950

# =============================================================
# CI/CD (NO van en .env del VPS — van en GitHub Secrets del repo)
# Documentadas acá solo como recordatorio:
# =============================================================
# VPS_HOST=49.13.x.x
# VPS_USER=ams
# VPS_SSH_KEY="-----BEGIN OPENSSH PRIVATE KEY----- ..."
# VPS_DEPLOY_PATH=/opt/ams/supply-chain-ams-stack
# VPS_HOST_FINGERPRINT="49.13.x.x ssh-ed25519 AAAAC3..."   # ssh-keyscan -t ed25519 IP
